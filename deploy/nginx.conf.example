# PhoneTrade — reverse proxy to the Next.js app on 127.0.0.1:3000
# Скопировать на сервер: /etc/nginx/sites-available/phonetrade
# Включить:  ln -s /etc/nginx/sites-available/phonetrade /etc/nginx/sites-enabled/
# Проверить: nginx -t  &&  systemctl reload nginx
# SSL:       certbot --nginx -d ВАШ_ДОМЕН -d www.ВАШ_ДОМЕН

server {
    listen 80;
    listen [::]:80;
    server_name ВАШ_ДОМЕН www.ВАШ_ДОМЕН;

    # Статика Next отдаётся приложением; при желании можно кэшировать /_next/static
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 60m;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    client_max_body_size 10m;
}
